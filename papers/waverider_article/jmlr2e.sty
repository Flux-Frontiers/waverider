%% jmlr2e.sty — minimal shim for JMLR 2e style commands
%% Defines the JMLR-specific macros so the paper compiles without the
%% official style file (useful for arXiv submissions and local builds).

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{jmlr2e}[2024/01/01 Minimal JMLR2e shim]

\RequirePackage{geometry}
\geometry{left=1.25in,right=1.25in,top=1.25in,bottom=1.25in}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}

% \ShortHeadings{short-title}{short-author}
\newcommand{\ShortHeadings}[2]{%
  \fancyhead[LO]{\small\itshape #1}%
  \fancyhead[RE]{\small\itshape #2}%
  \fancyhead[RO,LE]{\small\thepage}%
}

% \firstpageno{n}
\newcommand{\firstpageno}[1]{\setcounter{page}{#1}}

% \editor{name}  — printed as a footnote on the title page
\newcommand{\editor}[1]{%
  \renewcommand{\@editor}{#1}%
}
\newcommand{\@editor}{}
\let\old@maketitle\maketitle
\renewcommand{\maketitle}{%
  \old@maketitle
  \ifx\@editor\@empty\else
    \footnotetext{Editor: \@editor}%
  \fi
}

% Author-block helpers: \name, \email, \addr
% These are used inside \author{} and just format inline.
\newcommand{\name}[1]{#1}
\newcommand{\email}[1]{\texttt{#1}}
\newcommand{\addr}[1]{#1}

% keywords environment
\newenvironment{keywords}{%
  \par\smallskip\noindent\textbf{Keywords:}\ \ignorespaces
}{%
  \par\medskip
}
